<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="6dp"
                android:color="@color/tb_primary_glow" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@android:color/transparent" />
            <stroke
                android:width="4dp"
                android:color="@color/tb_primary" />
        </shape>
    </item>
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.45"
                android:endColor="@color/tb_ptt_inner_edge"
                android:gradientRadius="85%p"
                android:startColor="@color/tb_ptt_inner_center"
                android:type="radial" />
        </shape>
    </item>
    <item
        android:bottom="8dp"
        android:left="8dp"
        android:right="8dp"
        android:top="8dp">
        <shape android:shape="oval">
            <solid android:color="@color/tb_primary_dim" />
        </shape>
    </item>
</layer-list>
