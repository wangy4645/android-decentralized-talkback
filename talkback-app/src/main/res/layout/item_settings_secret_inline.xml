<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <TextView
        android:id="@+id/txtSharedSecretLabel"
        style="@style/SettingsRowTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/settings_shared_secret_label" />

    <com.google.android.material.textfield.TextInputLayout
        style="@style/SettingsSecretTextInputLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        app:endIconContentDescription="@string/settings_toggle_secret_visibility">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/inputSharedSecret"
            style="@style/SettingsSecretTextInputEditText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="textPassword" />
    </com.google.android.material.textfield.TextInputLayout>

    <TextView
        android:id="@+id/txtSecretWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/settings_secret_required_warning"
        android:textColor="@color/tb_danger"
        android:textSize="12sp"
        android:visibility="gone" />

    <View
        android:id="@+id/dividerSecretRow"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="@color/tb_divider"
        android:visibility="gone" />
</LinearLayout>
