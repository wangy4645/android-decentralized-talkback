<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tb_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/settings_subpage_padding">

        <include layout="@layout/include_settings_toolbar" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="14dp">

            <ImageView
                android:layout_width="@dimen/settings_row_icon_size"
                android:layout_height="@dimen/settings_row_icon_size"
                android:contentDescription="@null"
                android:src="@drawable/ic_settings_network_status" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    style="@style/SettingsRowTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_network_status_title" />

                <TextView
                    android:id="@+id/txtNetworkQuality"
                    style="@style/SettingsRowValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="4dp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/txtNetworkDetail"
            style="@style/SettingsHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="10dp" />

        <TextView
            android:id="@+id/txtNetworkTransport"
            style="@style/SettingsHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:visibility="gone" />

        <TextView
            style="@style/SettingsHintText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:text="@string/settings_network_status_hint" />
    </LinearLayout>
</ScrollView>
