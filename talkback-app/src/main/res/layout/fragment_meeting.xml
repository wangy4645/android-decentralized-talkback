<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tb_bg">

    <LinearLayout
        android:id="@+id/panelMeetingMain"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnMeetingBack"
                style="@style/TalkbackToolbarIconButton"
                android:contentDescription="@string/cd_settings_back"
                android:src="@drawable/ic_settings_back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtMeetingHeader"
                    style="@style/SettingsRowTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txtMeetingSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:textColor="@color/tb_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/btnMeetingLeaveTop"
                style="@style/TalkbackToolbarIconButton"
                android:contentDescription="@string/meeting_leave"
                android:src="@drawable/ic_call_end"
                app:tint="@color/tb_danger" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtMeetingStatusPill"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_call_online_pill"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:text="@string/conference_status_live"
                android:textColor="@color/tb_success"
                android:textSize="11sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/txtMeetingTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:text="00:00:00"
                android:textColor="@color/tb_text_primary"
                android:textSize="13sp" />

            <TextView
                android:id="@+id/txtMeetingParticipantCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:textColor="@color/tb_text_muted"
                android:textSize="12sp" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1">

            <LinearLayout
                android:id="@+id/panelMeetingConnecting"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:visibility="gone">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.talkback.appprod.ui.MeetingConnectingLoaderView
                    android:layout_width="168dp"
                    android:layout_height="168dp"
                    android:contentDescription="@string/meeting_connecting" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/meeting_connecting"
                    android:textColor="@color/tb_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/meeting_connecting_hint"
                    android:textColor="@color/tb_text_muted"
                    android:textSize="13sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/panelMeetingLive"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:id="@+id/txtMeetingPoorNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_card"
                    android:gravity="center"
                    android:padding="10dp"
                    android:text="@string/meeting_poor_network_hint"
                    android:textColor="@color/tb_warning"
                    android:textSize="11sp"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/blockMeetingSpeaker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <FrameLayout
                            android:id="@+id/frameMeetingAvatarOuter"
                            android:layout_width="@dimen/meeting_speaker_outer_size"
                            android:layout_height="@dimen/meeting_speaker_outer_size"
                            android:background="@drawable/bg_meeting_speaker_outer_ring">

                            <FrameLayout
                                android:id="@+id/frameMeetingAvatarInner"
                                android:layout_width="@dimen/meeting_speaker_inner_size"
                                android:layout_height="@dimen/meeting_speaker_inner_size"
                                android:layout_gravity="center"
                                android:background="@drawable/bg_meeting_speaker_inner_ring">

                                <ImageView
                                    android:id="@+id/imgMeetingSpeakerAvatar"
                                    android:layout_width="@dimen/meeting_speaker_icon_size"
                                    android:layout_height="@dimen/meeting_speaker_icon_size"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_call_avatar_person" />

                                <ImageView
                                    android:id="@+id/imgMeetingMutedIcon"
                                    android:layout_width="@dimen/meeting_speaker_icon_size"
                                    android:layout_height="@dimen/meeting_speaker_icon_size"
                                    android:layout_gravity="center"
                                    android:contentDescription="@null"
                                    android:src="@drawable/ic_mic_off"
                                    android:visibility="gone" />
                            </FrameLayout>
                        </FrameLayout>

                        <com.talkback.appprod.ui.MeetingVolumeMeterView
                            android:id="@+id/meterMeetingVolume"
                            android:layout_width="@dimen/meeting_volume_meter_width"
                            android:layout_height="@dimen/meeting_volume_meter_height"
                            android:layout_marginStart="@dimen/meeting_volume_meter_gap"
                            android:contentDescription="@string/cd_meeting_volume_meter" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/txtMeetingSpeaker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textColor="@color/tb_text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtMeetingSpeakerStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/meeting_speaking"
                        android:textColor="@color/tb_primary"
                        android:textSize="12sp" />
                </LinearLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:id="@+id/containerMeetingAvatars"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal" />
                </HorizontalScrollView>
            </LinearLayout>
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMeetingCancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/meeting_cancel"
            android:textColor="@color/tb_text_primary"
            android:visibility="gone"
            app:strokeColor="@color/tb_divider"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:id="@+id/rowMeetingControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <include
                android:id="@+id/btnMeetingMute"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/btnMeetingSpeaker"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/btnMeetingHeadset"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/btnMeetingMore"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMeetingLeave"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="@color/tb_danger"
            android:text="@string/meeting_leave"
            android:textColor="@color/tb_white"
            android:visibility="gone" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/meetingSubContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/tb_bg"
        android:visibility="gone" />

</FrameLayout>
