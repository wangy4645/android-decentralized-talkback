<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="6dp"
    android:background="@drawable/bg_endpoint_item"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingHorizontal="10dp"
    android:paddingVertical="8dp">

    <View
        android:id="@+id/dotStatus"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:background="@drawable/dot_online" />

    <FrameLayout
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_avatar_circle">

        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:contentDescription="@null"
            android:src="@drawable/ic_avatar_person" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtEndpointKey"
            style="@style/TalkbackEndpointName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="M01 / E01" />

        <TextView
            android:id="@+id/txtEndpointStatus"
            style="@style/TalkbackEndpointStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingTop="2dp"
            android:text="@string/status_online"
            android:textColor="@color/tb_success" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgWaveform"
        android:layout_width="28dp"
        android:layout_height="14dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_waveform"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/imgSignalBars"
        android:layout_width="22dp"
        android:layout_height="16dp"
        android:contentDescription="@null"
        android:src="@drawable/ic_signal_bars" />
</LinearLayout>
