<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/txtProfileName"
            style="@style/SettingsRowTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1" />

        <TextView
            android:id="@+id/txtProfileActive"
            style="@style/TaskProfileActiveChipText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_task_action_switch"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:text="@string/task_profile_active_badge"
            android:visibility="gone" />
    </LinearLayout>

    <TextView
        android:id="@+id/txtProfileMeta"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@color/tb_text_muted"
        android:textSize="10sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnEditProfile"
            style="@style/TaskProfileActionText.Edit"
            android:layout_marginEnd="4dp"
            android:text="@string/task_profile_edit" />

        <TextView
            android:id="@+id/btnSwitchProfile"
            style="@style/TaskProfileActionText.Switch"
            android:layout_marginEnd="4dp"
            android:text="@string/task_profile_switch" />

        <TextView
            android:id="@+id/btnDeleteProfile"
            style="@style/TaskProfileActionText.Delete"
            android:text="@string/task_profile_delete" />
    </LinearLayout>
</LinearLayout>
