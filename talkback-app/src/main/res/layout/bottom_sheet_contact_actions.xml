<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/tb_surface"
    android:orientation="vertical"
    android:paddingBottom="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:background="@color/tb_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_avatar_circle">

            <ImageView
                android:layout_width="26dp"
                android:layout_height="26dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_avatar_person" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtSheetName"
                style="@style/SettingsRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/txtSheetTeam"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textColor="@color/tb_text_muted"
                android:textSize="13sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtSheetOnline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_online_pill"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="@string/status_online"
            android:textColor="@color/tb_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/tb_divider" />

    <include
        android:id="@+id/actionPrivateCall"
        layout="@layout/item_contact_action_row" />

    <include
        android:id="@+id/actionMonitor"
        layout="@layout/item_contact_action_row" />

    <include
        android:id="@+id/actionMessage"
        layout="@layout/item_contact_action_row" />

    <include
        android:id="@+id/actionFavorite"
        layout="@layout/item_contact_action_row" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSheetCancel"
        style="@style/Widget.Material3.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:text="@string/call_action_cancel"
        android:textColor="@color/tb_text_secondary" />

</LinearLayout>
