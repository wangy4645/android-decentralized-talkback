<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tb_bg">

    <LinearLayout
        android:id="@+id/panelActiveCall"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btnCallBack"
                style="@style/TalkbackToolbarIconButton"
                android:contentDescription="@string/cd_settings_back"
                android:src="@drawable/ic_settings_back" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/txtHeaderName"
                    style="@style/SettingsRowTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/txtHeaderTeam"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="2dp"
                    android:textColor="@color/tb_text_muted"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtHeaderOnline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_online_pill"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:text="@string/status_online"
                android:textColor="@color/tb_primary"
                android:textSize="10sp"
                android:visibility="gone" />
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/txtCallOnline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="8dp"
                android:background="@drawable/bg_call_online_pill"
                android:includeFontPadding="false"
                android:paddingHorizontal="6dp"
                android:paddingVertical="2dp"
                android:text="@string/status_online"
                android:textColor="@color/tb_success"
                android:textSize="9sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgWaveLeft"
                    android:layout_width="36dp"
                    android:layout_height="20dp"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_waveform"
                    android:tint="@color/tb_primary" />

                <FrameLayout
                    android:layout_width="@dimen/call_avatar_ring_size"
                    android:layout_height="@dimen/call_avatar_ring_size"
                    android:layout_marginHorizontal="12dp"
                    android:background="@drawable/bg_ptt_radar_ring">

                    <FrameLayout
                        android:layout_width="@dimen/call_avatar_inner_size"
                        android:layout_height="@dimen/call_avatar_inner_size"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_call_avatar_inner">

                        <ImageView
                            android:layout_width="@dimen/call_avatar_icon_size"
                            android:layout_height="@dimen/call_avatar_icon_size"
                            android:layout_gravity="center"
                            android:contentDescription="@null"
                            android:src="@drawable/ic_call_avatar_person" />
                    </FrameLayout>
                </FrameLayout>

                <ImageView
                    android:id="@+id/imgWaveRight"
                    android:layout_width="36dp"
                    android:layout_height="20dp"
                    android:alpha="0"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_waveform"
                    android:tint="@color/tb_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtCallRemote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/tb_text_primary"
                android:textSize="16sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/imgStatusWave"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:layout_marginEnd="4dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_waveform"
                    android:tint="@color/tb_primary"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/txtCallStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/tb_primary"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/txtCallTimer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:fontFamily="monospace"
                android:textColor="@color/tb_text_primary"
                android:textSize="11sp"
                android:visibility="gone" />
            </LinearLayout>
        </FrameLayout>

        <LinearLayout
            android:id="@+id/rowQosStats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_signal_bars" />

                <TextView
                    style="@style/CallQosLabel"
                    android:text="@string/call_qos_network" />

                <TextView
                    android:id="@+id/txtQosNetwork"
                    style="@style/CallQosValue" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_qos_clock" />

                <TextView
                    style="@style/CallQosLabel"
                    android:text="@string/call_qos_rtt" />

                <TextView
                    android:id="@+id/txtQosRtt"
                    style="@style/CallQosValue" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_qos_wave_circle" />

                <TextView
                    style="@style/CallQosLabel"
                    android:text="@string/call_qos_loss" />

                <TextView
                    android:id="@+id/txtQosLoss"
                    style="@style/CallQosValueSuccess" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_qos_wave_circle" />

                <TextView
                    style="@style/CallQosLabel"
                    android:text="@string/call_qos_codec" />

                <TextView
                    android:id="@+id/txtQosCodec"
                    style="@style/CallQosValue" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowIncomingActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/CallIncomingDeclineButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="@string/call_reject" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAccept"
                style="@style/CallIncomingAcceptButton"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="@string/call_accept" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/rowInCallControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <include
                android:id="@+id/btnMute"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/btnSpeaker"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/btnHeadset"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <include
                android:id="@+id/btnMore"
                layout="@layout/item_call_control_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/btnEndCall"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/call_end_button_height"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/bg_call_end_button"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/call_end_button_padding_h"
            android:visibility="gone">

            <ImageView
                android:layout_width="@dimen/call_end_icon_width"
                android:layout_height="@dimen/call_end_icon_height"
                android:contentDescription="@null"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_call_end_handset" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:text="@string/call_end"
                android:textColor="@color/tb_white"
                android:textSize="15sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/panelCallEnded"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:paddingHorizontal="20dp"
        android:paddingTop="32dp"
        android:paddingBottom="16dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <ImageView
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:contentDescription="@null"
                android:src="@drawable/ic_call_check" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:text="@string/call_ended_title"
                android:textColor="@color/tb_text_primary"
                android:textSize="@dimen/call_ended_title_text_size"
                android:textStyle="normal" />

            <TextView
                android:id="@+id/txtEndedDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="sans-serif"
                android:includeFontPadding="false"
                android:textColor="@color/tb_text_muted"
                android:textSize="@dimen/call_ended_duration_text_size"
                android:textStyle="normal" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:text="@string/call_summary_title"
                    android:textColor="@color/tb_primary"
                    android:textSize="@dimen/call_ended_summary_title_text_size"
                    android:textStyle="normal" />

                <TextView
                    android:id="@+id/txtSummaryBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="sans-serif"
                    android:includeFontPadding="false"
                    android:lineSpacingExtra="3dp"
                    android:textColor="@color/tb_text_secondary"
                    android:textSize="@dimen/call_ended_summary_body_text_size"
                    android:textStyle="normal" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="24dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBackToContacts"
                style="@style/CallEndedBackButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/call_back_to_contacts" />
        </LinearLayout>
    </ScrollView>

</FrameLayout>
