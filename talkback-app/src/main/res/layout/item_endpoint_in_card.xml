<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/endpointRowContent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="10dp">

        <View
            android:id="@+id/dotStatus"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_online" />

        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:background="@drawable/bg_avatar_circle">

            <ImageView
                android:id="@+id/imgAvatar"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:contentDescription="@null"
                android:src="@drawable/ic_avatar_person" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtEndpointKey"
                style="@style/SettingsRowTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxLines="1"
                android:singleLine="true" />

            <TextView
                android:id="@+id/txtEndpointTeam"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="1dp"
                android:textColor="@color/tb_text_muted"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/txtEndpointStatus"
                style="@style/TalkbackEndpointStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="2dp"
                android:textSize="@dimen/settings_row_value_text_size" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgWaveform"
            android:layout_width="28dp"
            android:layout_height="14dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_waveform"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imgSignalBars"
            android:layout_width="22dp"
            android:layout_height="16dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_signal_bars" />
    </LinearLayout>

    <View
        android:id="@+id/dividerBottom"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="56dp"
        android:background="@color/tb_divider" />
</LinearLayout>
