<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TalkbackTileLabel">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">@dimen/tb_tile_label_text_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TalkbackEndpointHeader">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_text_primary</item>
        <item name="android:textSize">@dimen/tb_endpoint_header_text_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
    </style>

    <style name="TalkbackEndpointName">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">@dimen/tb_endpoint_name_text_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
        <item name="android:ellipsize">end</item>
        <item name="android:textColor">@color/tb_text_primary</item>
    </style>

    <style name="TalkbackToolbarIconButton" parent="Widget.AppCompat.ImageButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:padding">12dp</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <style name="SettingsEditText">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/tb_text_primary</item>
        <item name="android:textColorHint">@color/tb_text_muted</item>
        <item name="android:textSize">@dimen/settings_input_text_size</item>
    </style>

    <style name="SettingsTextInputEditText" parent="Widget.AppCompat.EditText">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingVertical">8dp</item>
        <item name="android:textColor">@color/tb_text_primary</item>
        <item name="android:textSize">@dimen/settings_input_text_size</item>
    </style>

    <style name="TextAppearance.Settings.Hint" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_text_muted</item>
        <item name="android:textSize">@dimen/settings_hint_text_size</item>
    </style>

    <style name="SettingsTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="android:layout_marginTop">4dp</item>
        <item name="hintTextAppearance">@style/TextAppearance.Settings.Hint</item>
    </style>

    <style name="SettingsSecretTextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="boxBackgroundMode">none</item>
        <item name="boxCollapsedPaddingTop">0dp</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="endIconMode">password_toggle</item>
        <item name="endIconTint">@color/tb_text_secondary</item>
        <item name="passwordToggleTint">@color/tb_text_secondary</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="SettingsEditTextPasswordLayout" parent="Widget.MaterialComponents.TextInputLayout.FilledBox">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">6dp</item>
        <item name="boxBackgroundMode">none</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">0dp</item>
        <item name="endIconMode">password_toggle</item>
        <item name="endIconTint">@color/tb_text_secondary</item>
        <item name="passwordToggleTint">@color/tb_text_secondary</item>
        <item name="hintEnabled">false</item>
    </style>

    <style name="SettingsSecretTextInputEditText" parent="SettingsTextInputEditText">
        <item name="android:paddingStart">0dp</item>
        <item name="android:paddingEnd">0dp</item>
        <item name="android:paddingTop">2dp</item>
        <item name="android:paddingBottom">2dp</item>
        <item name="android:minHeight">0dp</item>
    </style>

    <style name="SettingsHintText">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_text_muted</item>
        <item name="android:textSize">@dimen/settings_hint_text_size</item>
    </style>

    <style name="SettingsDescText">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:lineSpacingExtra">2dp</item>
        <item name="android:textColor">@color/tb_text_secondary</item>
        <item name="android:textSize">@dimen/settings_desc_text_size</item>
    </style>

    <style name="SettingsSwitchLabel">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:textColor">@color/tb_text_secondary</item>
        <item name="android:textSize">@dimen/settings_switch_text_size</item>
    </style>

    <style name="SettingsSwitch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="android:showText">false</item>
        <item name="android:textColor">@color/tb_text_primary</item>
    </style>

    <style name="SettingsPrimaryButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">@dimen/settings_button_text_size</item>
    </style>

    <style name="SettingsOutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">40dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/tb_text_secondary</item>
        <item name="android:textSize">@dimen/settings_button_text_size</item>
    </style>

    <style name="SettingsFieldLabel">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingBottom">4dp</item>
        <item name="android:textColor">@color/tb_text_secondary</item>
        <item name="android:textSize">11sp</item>
    </style>

    <style name="SettingsPriorityOption" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingStart">0dp</item>
        <item name="android:textColor">@color/tb_text_secondary</item>
        <item name="android:textSize">@dimen/settings_hint_text_size</item>
    </style>

    <style name="TaskProfileActionText">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_weight">1</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:minHeight">32dp</item>
        <item name="android:paddingHorizontal">4dp</item>
        <item name="android:paddingVertical">6dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TaskProfileActionText.Edit">
        <item name="android:background">@drawable/bg_task_action_edit</item>
        <item name="android:textColor">@color/tb_monitor</item>
    </style>

    <style name="TaskProfileActiveChipText">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_success</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TaskProfileActionText.Switch">
        <item name="android:background">@drawable/bg_task_action_switch</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/tb_success</item>
    </style>

    <style name="TaskProfileActionText.Delete">
        <item name="android:background">@drawable/bg_task_action_delete</item>
        <item name="android:textColor">@color/tb_danger</item>
    </style>

    <style name="SettingsSectionLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingBottom">6dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textColor">@color/tb_text_muted</item>
        <item name="android:textSize">@dimen/settings_section_label_text_size</item>
        <item name="android:textStyle">normal</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="SettingsRowTitle">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_text_primary</item>
        <item name="android:textSize">@dimen/settings_row_title_text_size</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="SettingsRowValue">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_text_muted</item>
        <item name="android:textSize">@dimen/settings_row_value_text_size</item>
        <item name="android:textStyle">normal</item>
    </style>

    <style name="SettingsStatusEnabled">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textColor">@color/tb_success</item>
        <item name="android:textSize">@dimen/settings_hint_text_size</item>
    </style>

    <style name="SettingsBadgePlanned">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">@drawable/bg_settings_badge_planned</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:paddingHorizontal">8dp</item>
        <item name="android:paddingVertical">3dp</item>
        <item name="android:textColor">@color/tb_text_muted</item>
        <item name="android:textSize">10sp</item>
    </style>

    <style name="TalkbackEndpointStatus">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">normal</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:textSize">@dimen/tb_endpoint_status_text_size</item>
        <item name="android:maxLines">1</item>
        <item name="android:singleLine">true</item>
    </style>

    <style name="CallEndedBackButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textSize">14sp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="CallIncomingAcceptButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">@dimen/call_incoming_button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/tb_white</item>
        <item name="android:textSize">@dimen/call_incoming_button_text_size</item>
        <item name="backgroundTint">@color/tb_success</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="CallIncomingDeclineButton" parent="Widget.MaterialComponents.Button">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:minHeight">@dimen/call_incoming_button_min_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/tb_white</item>
        <item name="android:textSize">@dimen/call_incoming_button_text_size</item>
        <item name="backgroundTint">@color/tb_danger</item>
        <item name="cornerRadius">12dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="CallQosLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">5dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">@color/tb_text_secondary</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="CallQosValue">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">@color/tb_primary</item>
        <item name="android:textSize">9sp</item>
    </style>

    <style name="CallQosValueSuccess">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">2dp</item>
        <item name="android:maxLines">1</item>
        <item name="android:textColor">@color/tb_success</item>
        <item name="android:textSize">9sp</item>
    </style>
</resources>
